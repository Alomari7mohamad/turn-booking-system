# ===== Database (MySQL) =====
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/turn_booking"

# ===== Server =====
PORT=4000
NODE_ENV=development

# ===== Auth =====
JWT_SECRET="put-a-long-random-secret-here"
JWT_EXPIRES_IN="7d"

# ===== CORS =====
CLIENT_URL="http://localhost:5173"

# ===== Payment =====
PAYMENT_PROVIDER="mock"
PAYMENT_WEBHOOK_SECRET="put-a-secret-here"

# ===== Booking phone verification =====
# مؤقتًا للتجربة: true يعطل رمز واتساب، false يعيد التحقق.
DISABLE_PHONE_VERIFICATION="true"
